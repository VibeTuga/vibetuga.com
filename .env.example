# ==============================================
# VibeTuga — Environment Variables
# ==============================================
# Copy this file to .env.local and fill in the values.

# --- Database (Neon DB) ---
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- Auth (NextAuth.js v5 / Auth.js) ---
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# --- Discord OAuth ---
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Platform fee percentage for Stripe Connect seller payouts (default: 15)
STRIPE_CONNECT_PLATFORM_FEE_PERCENT=15

# --- Email (Resend) ---
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=
# Sender address (must be a verified domain in Resend)
EMAIL_FROM=VibeTuga <noreply@vibetuga.com>

# --- File Storage (Cloudflare R2) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Cron Jobs ---
# Secret token for authenticating automated cron requests to protected API routes
# Generate with: openssl rand -base64 32
CRON_SECRET=

# --- Public API (v1) ---
# Rate limit for API key authenticated requests (requests per minute per key)
API_RATE_LIMIT_PER_MINUTE=100

# --- Error Monitoring (Sentry) ---
# Client-side DSN (public, used in browser)
NEXT_PUBLIC_SENTRY_DSN=
# Server-side DSN (used in Node.js and Edge runtimes)
SENTRY_DSN=
# Auth token for uploading source maps during production builds
# Generate at https://sentry.io/settings/auth-tokens/
SENTRY_AUTH_TOKEN=
# Sentry organization slug
SENTRY_ORG=
# Sentry project slug
SENTRY_PROJECT=
